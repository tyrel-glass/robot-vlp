    "## map the co-ordinates between the cnc and floor\n",
    "\n",
    "def build_cnc_converter():\n",
    "    log_file = 'floor_cnc_cal_map.csv'\n",
    "    transformer = c.build_transformer(log_file)\n",
    "    df = pd.read_csv(log_file, delimiter='|', header=0,)\n",
    "    df.columns = ['vive_data', 'vlp_data', 'last_cmd']\n",
    "\n",
    "    vive_positions = df['vive_data'].apply(\n",
    "        lambda v: np.fromstring(v.strip('[]'), sep=' ')[:3]\n",
    "    )\n",
    "    df['vive_data'] = vive_positions\n",
    "    df['new_vive'] = df['vive_data'].apply(transformer.transform_point)\n",
    "    cnc_x_0 = df['new_vive'].iloc[4][0]\n",
    "    cnc_y_0 = df['new_vive'].iloc[4][2]\n",
    "\n",
    "    def transform_cnc_to_room(cnc_point):\n",
    "\n",
    "\n",
    "        cnc_x = cnc_point[0]\n",
    "        cnc_y = cnc_point[1]\n",
    "        new_cnc_x = cnc_x + cnc_x_0\n",
    "        new_cnc_y = cnc_y + cnc_y_0\n",
    "\n",
    "        return [new_cnc_x, new_cnc_y]\n",
    "    return transform_cnc_to_room\n",
    "transform_cnc_to_room = build_cnc_converter()"
   ]
